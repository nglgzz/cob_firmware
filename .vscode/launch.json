{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "cwd": "${workspaceRoot}",
      "executable": "./bin/final.elf",
      "name": "Flash & Debug with OpenOCD",
      "request": "launch",
      "type": "cortex-debug",
      "servertype": "openocd",
      "gdbPath": "gdb-multiarch",
      "configFiles": ["/usr/share/openocd/scripts/board/nordic_nrf52_dk.cfg"],
      "preLaunchTask": "flash",
      "searchDir": [],
      "runToEntryPoint": "main",
      "showDevDebugOutput": "none"
    }
  ]
}
