  "version": "0.2.0",
  "configurations": [
    {
      "cwd": "${workspaceRoot}",
      "executable": "./build1/src/mmk_firmware.elf",
      "name": "Flash & Debug with OpenOCD (1)",
      "request": "launch",
      "type": "cortex-debug",
      "servertype": "openocd",
      "serverArgs": ["-c", "jlink serial 1050232668"],
      "gdbPath": "gdb-multiarch",
      "configFiles": ["/usr/share/openocd/scripts/board/nordic_nrf52_dk.cfg"],
      "preLaunchTask": "flash1",
      "searchDir": [],
      "runToEntryPoint": "main",
      "showDevDebugOutput": "none"
    },
    {
      "cwd": "${workspaceRoot}",
      "executable": "./build2/src/mmk_firmware.elf",
      "name": "Flash & Debug with OpenOCD (2)",
      "request": "launch",
      "type": "cortex-debug",
      "servertype": "openocd",
      "serverArgs": ["-c", "jlink serial 1050276985"],
      "gdbPath": "gdb-multiarch",
      "configFiles": ["/usr/share/openocd/scripts/board/nordic_nrf52_dk.cfg"],
      "preLaunchTask": "flash2",
      "searchDir": [],
      "runToEntryPoint": "main",
      "showDevDebugOutput": "none"
    }
  ]
}
